# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payment provider: stripe (default) | external (legacy SellAuth URLs)
PAYMENT_PROVIDER=stripe

# Stripe mode: test (sandbox) | live
# Keep test while validating checkout. Switch to live only when ready for real payments.
STRIPE_MODE=test

# Stripe (required when PAYMENT_PROVIDER=stripe)
# Test/sandbox keys: sk_test_..., pk_test_..., whsec_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Map catalog product IDs to Stripe Price IDs (server-only JSON object).
# Run: pnpm stripe:setup-test-prices
# Then paste the generated map here.
# Example (replace price_xxx with IDs from Stripe Dashboard or setup script):
# STRIPE_PRICE_MAP={"all-in-one-supplier-vault":"price_xxx","reselling-blueprint":"price_xxx","receipt-generator":"price_xxx","airpods-pro-2":"price_xxx","airpods-pro-3":"price_xxx","airpods-4-anc":"price_xxx","airpods-max":"price_xxx","lv-imagination-vendor":"price_xxx","rolex-vendor":"price_xxx","nike-shox-vendor":"price_xxx","iphone-17-pro":"price_xxx","prada-glasses":"price_xxx"}
STRIPE_PRICE_MAP=

# Social links (optional — hidden on success page when unset)
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/WvYNE5xrvr
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Stripe test/sandbox checklist
# 1. Set STRIPE_MODE=test and use test keys from Stripe Dashboard
# 2. Create Products + Prices in Stripe test mode (EUR), or run: pnpm stripe:setup-test-prices
# 3. Set STRIPE_PRICE_MAP with all catalog product IDs
# 4. Verify config locally: pnpm stripe:verify
# 5. Local webhooks: stripe listen --forward-to localhost:3000/api/webhooks/stripe
#    Use the CLI whsec_... value as STRIPE_WEBHOOK_SECRET for local dev
# 6. Deployed webhooks: https://your-domain.com/api/webhooks/stripe
#    Events: checkout.session.completed, checkout.session.expired
# 7. Checkout URLs (set by API):
#    Success: {NEXT_PUBLIC_SITE_URL}/success?session_id={CHECKOUT_SESSION_ID}
#    Cancel:  {NEXT_PUBLIC_SITE_URL}/checkout/cancel
