# Site
NEXT_PUBLIC_SITE_URL=https://skroojmoney.com

# Payment provider: external (legacy SellAuth URLs) | stripe
PAYMENT_PROVIDER=external

# Stripe (required when PAYMENT_PROVIDER=stripe)
# Production: use live keys (sk_live_..., pk_live_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: map product IDs to Stripe Price IDs (server-only JSON object)
# Example:
# STRIPE_PRICE_MAP={"all-in-one-supplier-vault":"price_xxx","reselling-blueprint":"price_yyy"}
STRIPE_PRICE_MAP=

# Social links (optional — hidden on success page when unset)
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/WvYNE5xrvr
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Stripe setup checklist (production)
# 1. Create Products + Prices in Stripe Dashboard (EUR)
# 2. Set STRIPE_PRICE_MAP or stripePriceId per product in store data
# 3. Set PAYMENT_PROVIDER=stripe
# 4. Add env vars to hosting (Vercel, etc.)
# 5. Register webhook endpoint: https://your-domain.com/api/webhooks/stripe
#    Events: checkout.session.completed, checkout.session.expired
# 6. Set success URL in Stripe Checkout (handled by API): /success?session_id={CHECKOUT_SESSION_ID}
# 7. Cancel URL: /checkout/cancel
